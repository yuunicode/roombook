# Frontend port exposed from the internal app host PC.
FRONTEND_PORT=8080

# Backend runtime
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Current NAS DB runtime:
# - NAS admin UI: http://192.168.0.22:5555/
# - PostgreSQL host: 192.168.0.22
# - container name: postgres-roombook
# - published port: 5432
# Replace the password with the real operating value.
DATABASE_URL=postgresql+asyncpg://roombook:change-this-db-password@192.168.0.22:5432/roombook

SESSION_SIGNING_SECRET=replace-with-a-long-random-secret

# If users access the app through plain HTTP inside the intranet, keep this false.
# If you put HTTPS reverse proxy in front, change to true.
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

OPENAI_API_KEY=

# On the first backend start, seed company users into the NAS DB.
AUTO_SEED_USERS=true
