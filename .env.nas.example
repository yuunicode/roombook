# NAS host port for the frontend container.
FRONTEND_PORT=8080

# PostgreSQL
POSTGRES_DB=roombook
POSTGRES_USER=roombook
POSTGRES_PASSWORD=change-this-db-password

# Backend runtime
HOST=0.0.0.0
PORT=8000
DEBUG=false
DATABASE_URL=postgresql+asyncpg://roombook:change-this-db-password@postgres:5432/roombook
SESSION_SIGNING_SECRET=replace-with-a-long-random-secret
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
OPENAI_API_KEY=
